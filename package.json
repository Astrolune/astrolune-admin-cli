{
  "name": "@astrolune/admin-cli",
  "version": "0.1.0",
  "description": "Astrolune Admin CLI for platform operations",
  "type": "module",
  "bin": {
    "astrolune-admin": "./dist/index.js"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "check": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "dev": "node ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "astrolune",
    "admin",
    "cli"
  ],
  "author": "Astrolune",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
